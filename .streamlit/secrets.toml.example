# このファイルは「見本」です。
# ローカルで試すときは secrets.toml にコピーして値を入れてください。
# 公開（Streamlit Community Cloud）するときは「Settings → Secrets」に貼り付けます。
# GitHub には本物の値を上げないこと。

# === AI（必須）===
# パソコンの環境変数 ANTHROPIC_API_KEY が設定済みなら、ここは空でもローカルは動きます。
ANTHROPIC_API_KEY = "sk-ant-ここにAnthropicのAPIキー"

# === 会員データベース（公開時に設定）===
# 空ならローカルのSQLite(members.db)を使います。
# 公開時は Neon などの無料Postgresの接続URLを入れると、データが消えずに永続化されます。
# DATABASE_URL = "postgresql://ユーザー:パスワード@ホスト/データベース"

# === 決済（Stripe）===
# 空のあいだは「テスト用 手動有効化」ボタンで動作確認できます。
# STRIPE_SECRET_KEY = "sk_test_..."     # まずはテストモードのキー
# STRIPE_PRICE_ID   = "price_..."       # 月額990円プランのPrice ID
# APP_BASE_URL      = "http://localhost:8501"   # 公開時は本番URLに変更

# === 旧・合言葉ゲート（会員制に移行したため通常は不要）===
# APP_PASSWORD = ""
